# Template for the nested, multi-site test configuration (~/.evn_test.yaml).
# Read by EvnConf (test_biolovision_api, test_transfer_vn ...).
# Render with envsubst, e.g.:
#   envsubst < tests/data/evn_test.yaml.tmpl > ~/.evn_test.yaml
# Required variables: VN_SITE_URL VN_USER_EMAIL VN_USER_PW VN_CLIENT_KEY
#   VN_CLIENT_SECRET DB_HOST DB_PORT DB_NAME DB_GROUP DB_USER DB_PW

# General parameters
main:
  admin_mail: nom.prenom@example.net

# Biolovision API controlers parameters
controler:
  entities:
    enabled: true
    schedule:
      day_of_week: 2
      hour: 23
  families:
    enabled: true
    schedule:
      day_of_week: 4
      hour: 23
  fields:
    enabled: true
    schedule:
      day_of_week: 2
      hour: 23
  local_admin_units:
    enabled: true
    schedule:
      day_of_week: 2
      hour: 23
  observations:
    enabled: true
    schedule:
      minute: 0
      second: 0
  observers:
    enabled: true
    schedule:
      hour: 22
  places:
    enabled: true
    schedule:
      hour: 5
  species:
    enabled: true
    schedule:
      hour: 6
  taxo_groups:
    enabled: true
    schedule:
      hour: 6
  territorial_units:
    enabled: true
    schedule:
      hour: 5
  validations:
    enabled: true
    schedule:
      day_of_week: 4
      hour: 23

# Observations filter, to limit download scope
filter:
  taxo_exclude:
    - TAXO_GROUP_ALIEN_PLANTS
  territorial_unit_ids:
    - 7
  json_format: short
  start_date: 2019-08-01
  end_date: 2019-09-01
  type_date: entry

# VisioNature site access parameters
site:
  tff:
    enabled: true
    site: ${VN_SITE_URL}
    user_email: ${VN_USER_EMAIL}
    user_pw: ${VN_USER_PW}
    client_key: ${VN_CLIENT_KEY}
    client_secret: ${VN_CLIENT_SECRET}

# File storage backend parameters
file:
  enabled: true
  file_store: test_files

# Postgresql backend related parameters
database:
  enabled: true
  db_host: ${DB_HOST}
  db_port: ${DB_PORT}
  db_name: ${DB_NAME}
  db_schema_import: import
  db_schema_vn: src_vn
  db_group: ${DB_GROUP}
  db_user: ${DB_USER}
  db_pw: ${DB_PW}
  db_secret_key: "mySecretKey"
  db_out_proj: 2154

# Tuning parameters, for expert use
tuning:
  max_list_length: 100
  max_chunks: 10
  max_retry: 5
  max_requests: 0
  retry_delay: 5
  unavailable_delay: 600
  lru_maxsize: 32
  pid_kp: 0.0
  pid_ki: 0.003
  pid_kd: 0.0
  pid_setpoint: 10000
  pid_limit_min: 1
  pid_limit_max: 2000
  pid_delta_days: 15
  sched_executors: 2
